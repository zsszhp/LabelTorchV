<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>标炬 (LabelTorch)</Name>
    <Version>1.0.0</Version>
    <Title>标炬工业缺陷检测软件</Title>
    <Publisher>LabelTorch Team</Publisher>
    <ProductUrl>https://github.com/zzsszhp/LabelTorchV</ProductUrl>
    <InstallerWindowIcon>logo.png</InstallerWindowIcon>
    <ApplicationIcon>logo.png</ApplicationIcon>
    <StartMenuDir>标炬</StartMenuDir>
    <TargetDir>@HomeDir@/LabelTorch</TargetDir>
    <AllowSpaceInPath>true</AllowSpaceInPath>
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>
    <RemoveTargetDir>true</RemoveTargetDir>
    <WizardShowPageList>
        <Page>Introduction</Page>
        <Page>TargetDirectory</Page>
        <Page>ComponentSelection</Page>
        <Page>ReadyForInstallation</Page>
        <Page>PerformInstallation</Page>
        <Page>InstallationFinished</Page>
    </WizardShowPageList>
    <MaintenanceToolName>maintenancetool</MaintenanceToolName>
    <PersistentLocalCache>false</PersistentLocalCache>
    <ControlScript>control.js</ControlScript>
    <DisableCancelDuringInstallation>false</DisableCancelDuringInstallation>
    <UseProductIcons>true</UseProductIcons>
    <RunProgram>@TargetDir@/labeltorch</RunProgram>
    <RunProgramArguments></RunProgramArguments>
    <RunProgramDescription>启动标炬</RunProgramDescription>
</Installer>
